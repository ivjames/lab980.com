#!/usr/bin/env bash
# lab980-provision — stand up the shell of a new lab980 site.
#
# Provisions, idempotently:
#   1. DigitalOcean DNS  — A record <stub>.<domain> -> droplet IP (via doctl)
#   2. app directory     — /var/www/<stub> (+ data/)
#   3. repo              — git clone (optional)
#   4. nginx vhost       — /etc/nginx/sites-available/<fqdn> -> local port
#   5. TLS               — certbot per-site cert (+ 80->443 redirect)
#
# It does NOT build or start the app — each site differs. After this runs,
# deploy the app however that project expects (e.g. its own bin/<name> + pm2).
set -euo pipefail

DOMAIN="lab980.com"
PORT=""
IP=""
DIR=""
DO_DNS=1
DO_TLS=1
DO_WWW=1
STUB=""
REPO=""

c_blue=$'\033[1;34m'; c_yellow=$'\033[1;33m'; c_red=$'\033[1;31m'; c_off=$'\033[0m'
log()  { printf '%s==>%s %s\n' "$c_blue" "$c_off" "$*"; }
warn() { printf '%swarn:%s %s\n' "$c_yellow" "$c_off" "$*" >&2; }
die()  { printf '%serror:%s %s\n' "$c_red" "$c_off" "$*" >&2; exit 1; }

usage() {
  cat <<'USAGE'
lab980-provision — scaffold a new lab980 subdomain (DNS, dir, repo, nginx, TLS).

Usage:
  lab980-provision <stub> [repo] [options]

  <stub>        subdomain label, e.g. "gigit"  ->  gigit.lab980.com;
                or "@" for the bare apex domain (server_name <domain>, plus
                www.<domain> unless --no-www).
  [repo]        git remote to clone: "owner/repo", a full https/ssh URL,
                or omit to just create an empty site dir.

Options:
  --domain D    base domain (default: lab980.com)
  --dir PATH    app directory (default: /var/www/<stub>, or /var/www/<domain>
                in apex mode)
  --port N      local port to reserve (default: next free from 8060)
  --ip IP       droplet public IP for DNS (default: auto via DO metadata)
  --no-dns      skip the DigitalOcean DNS record
  --no-tls      skip certbot (leave the site on :80)
  --no-www      apex mode only: don't also provision www.<domain>
  -h, --help    this help

  Apex example (e.g. moving a site to its own domain):
    provision-site @ ivjames/boxoffice --domain boxo.show --dir /var/www/boxoffice

Env:
  GITHUB_TOKEN  if set, used to clone private github.com repos over https.

Deliberately does NOT build or start the app.
USAGE
}

# ---- parse args ----
while [ $# -gt 0 ]; do
  case "$1" in
    --domain) DOMAIN="$2"; shift 2;;
    --dir)    DIR="$2"; shift 2;;
    --port)   PORT="$2"; shift 2;;
    --ip)     IP="$2"; shift 2;;
    --no-dns) DO_DNS=0; shift;;
    --no-tls) DO_TLS=0; shift;;
    --no-www) DO_WWW=0; shift;;
    -h|--help) usage; exit 0;;
    -*) die "unknown option: $1 (see --help)";;
    *) if [ -z "$STUB" ]; then STUB="$1"; elif [ -z "$REPO" ]; then REPO="$1"; else die "unexpected arg: $1"; fi; shift;;
  esac
done

[ -n "$STUB" ] || { usage; exit 1; }
[ "$(id -u)" -eq 0 ] || die "run as root."

# Apex mode: STUB "@" means the bare domain (server_name DOMAIN, plus
# www.DOMAIN unless --no-www) rather than a <stub>.DOMAIN subdomain. The DNS
# A record name for the apex is "@" in doctl.
if [ "$STUB" = "@" ]; then
  IS_APEX=1
  FQDN="$DOMAIN"
  RECORD_NAME="@"
  DEFAULT_DIRNAME="$DOMAIN"
else
  IS_APEX=0
  DO_WWW=0                        # www is an apex-only concern
  FQDN="$STUB.$DOMAIN"
  RECORD_NAME="$STUB"
  DEFAULT_DIRNAME="$STUB"
fi
DIR="${DIR:-/var/www/$DEFAULT_DIRNAME}"

log "Provisioning $FQDN  (dir: $DIR)"

# Detect the droplet's public IP once if we'll need it (DNS create and/or TLS wait).
if { [ "$DO_DNS" -eq 1 ] || [ "$DO_TLS" -eq 1 ]; } && [ -z "$IP" ]; then
  IP="$(curl -s --max-time 5 http://169.254.169.254/metadata/v1/interfaces/public/0/ipv4/address || true)"
fi

# ---- 1. DNS via doctl ----
if [ "$DO_DNS" -eq 1 ]; then
  command -v doctl >/dev/null || die "doctl not found (install/authenticate it, or pass --no-dns)."
  [ -n "$IP" ] || die "couldn't determine droplet IP for DNS; pass --ip."
  ensure_a_record() {           # $1 = record name ("@"/"www"/stub), $2 = fqdn (for logs)
    local rname="$1" rfqdn="$2" existing
    existing="$(doctl compute domain records list "$DOMAIN" --no-header --format Type,Name,Data 2>/dev/null \
                | awk -v n="$rname" '$1=="A" && $2==n {print $3}' | head -1)"
    if [ -n "$existing" ]; then
      log "DNS: A $rfqdn -> $existing already exists (leaving as-is)"
    else
      log "DNS: creating A $rfqdn -> $IP (ttl 300)"
      doctl compute domain records create "$DOMAIN" \
        --record-type A --record-name "$rname" --record-data "$IP" --record-ttl 300 >/dev/null
    fi
  }
  ensure_a_record "$RECORD_NAME" "$FQDN"
  [ "$DO_WWW" -eq 1 ] && ensure_a_record "www" "www.$DOMAIN"
fi

# ---- 2. app dir + 3. repo ----
if [ -n "$REPO" ] && [ ! -e "$DIR/.git" ]; then
  if [ -d "$DIR" ] && [ -n "$(ls -A "$DIR" 2>/dev/null)" ]; then
    die "$DIR exists and is not empty; refusing to clone over it."
  fi
  case "$REPO" in
    http*|git@*) url="$REPO";;
    */*)         url="https://github.com/$REPO.git";;
    *)           die "repo must be owner/repo or a git URL";;
  esac
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    case "$url" in
      https://github.com/*) url="https://x-access-token:${GITHUB_TOKEN}@github.com/${url#https://github.com/}";;
    esac
  fi
  log "repo: cloning into $DIR"
  git clone "$url" "$DIR"
elif [ -n "$REPO" ]; then
  log "repo: $DIR is already a git checkout (skipping clone)"
fi
mkdir -p "$DIR/data"

# ---- pick a free local port ----
if [ -z "$PORT" ]; then
  listening="$(ss -ltn 2>/dev/null | awk 'NR>1{print $4}' | sed 's/.*://' | sort -u)"
  in_nginx="$(grep -rhoE '127\.0\.0\.1:[0-9]+' /etc/nginx/sites-available 2>/dev/null | sed 's/.*://' | sort -u)"
  taken="$(printf '%s\n%s\n' "$listening" "$in_nginx")"
  for p in $(seq 8060 8099); do
    if ! printf '%s\n' "$taken" | grep -qx "$p"; then PORT="$p"; break; fi
  done
  [ -n "$PORT" ] || die "no free port in 8060-8099; pass --port."
fi
log "local port: $PORT"

# Seed PORT into the app's .env (convention: config in the app dir). Harmless if
# the app ignores it; skipped if an .env already exists.
if [ ! -f "$DIR/.env" ]; then
  printf 'PORT=%s\n' "$PORT" > "$DIR/.env"
  chmod 600 "$DIR/.env"
  log "wrote $DIR/.env (PORT=$PORT)"
fi

# ---- 4. nginx vhost ----
conf="/etc/nginx/sites-available/$FQDN"
if [ -f "$conf" ]; then
  log "nginx: $conf already exists (leaving as-is)"
else
  log "nginx: writing $conf (proxy -> 127.0.0.1:$PORT)"
  server_names="$FQDN"
  [ "$DO_WWW" -eq 1 ] && server_names="$FQDN www.$DOMAIN"
  cat > "$conf" <<EOF
server {
    listen 80;
    listen [::]:80;
    server_name $server_names;

    location / {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_read_timeout 60s;
    }
}
EOF
fi
ln -sf "$conf" "/etc/nginx/sites-enabled/$FQDN"
nginx -t && systemctl reload nginx
log "nginx: enabled and reloaded"

# ---- 5. TLS via certbot ----
if [ "$DO_TLS" -eq 1 ]; then
  if ! command -v certbot >/dev/null; then
    warn "certbot not found; skipping TLS. Install it, then: certbot --nginx -d $FQDN --redirect"
  else
    resolve() {
      if command -v dig >/dev/null; then dig +short "$1" | tail -1
      else getent hosts "$1" | awk '{print $1}' | head -1; fi
    }
    ok=0
    if [ -z "$IP" ]; then
      warn "droplet IP unknown; skipping DNS wait and attempting certbot directly."
      ok=1
    else
      log "waiting for $FQDN to resolve to $IP (up to ~5 min) ..."
      for _ in $(seq 1 30); do
        [ "$(resolve "$FQDN")" = "$IP" ] && { ok=1; break; }
        sleep 10
      done
    fi
    cert_args=(-d "$FQDN")
    [ "$DO_WWW" -eq 1 ] && cert_args+=(-d "www.$DOMAIN")
    if [ "$ok" -eq 1 ]; then
      log "TLS: issuing cert for ${cert_args[*]//-d /}"
      certbot --nginx "${cert_args[@]}" --redirect -n
    else
      warn "$FQDN not resolving to $IP yet (DNS still propagating)."
      warn "Re-run TLS later:  certbot --nginx ${cert_args[*]} --redirect -n"
    fi
  fi
fi

cat <<DONE

${c_blue}==>${c_off} Provisioned $FQDN
      dir:   $DIR
      port:  $PORT  (nginx proxies here)
      repo:  ${REPO:-<none>}

Next (per-site, not handled here): deploy the app so it listens on :$PORT.
Typical Node/Next flow:
  cd $DIR && npm ci && npm run build \\
    && PORT=$PORT pm2 start npm --name $STUB -- run start && pm2 save
DONE
