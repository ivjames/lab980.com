#!/usr/bin/env bash
# lab980-renew-certs — renew Let's Encrypt certs that are about to expire.
#
# What it does, in order:
#   1. Enumerate every installed cert under /etc/letsencrypt/live/*.
#   2. Isolate the ones whose leaf cert expires within the next N days
#      (default 2) by reading the notAfter date straight from cert.pem.
#   3. Issue a `certbot renew --cert-name <name>` for each due cert.
#
# certbot's own timer already renews at the 30-day mark; this is a tighter,
# explicit last-line-of-defense sweep for certs that slipped inside 2 days.
# Renewals go through the nginx installer, so nginx is reloaded with the new
# cert automatically (same as the certbot --nginx path used at provision time).
#
# Wire it to cron once on the droplet:  renew-certs --install-cron
set -euo pipefail

DAYS=2
DRY_RUN=0
FORCE=0
INSTALL_CRON=0
UNINSTALL_CRON=0
LE_LIVE="/etc/letsencrypt/live"
CRON_FILE="/etc/cron.d/lab980-renew-certs"
LOG_FILE="/var/log/lab980-renew-certs.log"
SELF="/usr/local/bin/renew-certs"

c_blue=$'\033[1;34m'; c_yellow=$'\033[1;33m'; c_red=$'\033[1;31m'; c_off=$'\033[0m'
log()  { printf '%s==>%s %s\n' "$c_blue" "$c_off" "$*"; }
warn() { printf '%swarn:%s %s\n' "$c_yellow" "$c_off" "$*" >&2; }
die()  { printf '%serror:%s %s\n' "$c_red" "$c_off" "$*" >&2; exit 1; }

usage() {
  cat <<'USAGE'
lab980-renew-certs — renew Let's Encrypt certs expiring within N days.

Usage:
  lab980-renew-certs [options]

Options:
  --days N          renew certs expiring within N days (default: 2)
  --force           pass --force-renewal to certbot (renew even if certbot
                    thinks it's too early; safe here since we pre-filter)
  --dry-run         ask certbot to simulate the renewal (no cert is replaced)
  --install-cron    write /etc/cron.d/lab980-renew-certs (twice-daily sweep)
                    and exit; does not renew anything
  --uninstall-cron  remove the cron.d entry and exit
  -h, --help        this help

Run manually to sweep now, or install the cron so it sweeps twice a day:
  renew-certs --install-cron
USAGE
}

# ---- parse args ----
while [ $# -gt 0 ]; do
  case "$1" in
    --days)           DAYS="$2"; shift 2;;
    --force)          FORCE=1; shift;;
    --dry-run)        DRY_RUN=1; shift;;
    --install-cron)   INSTALL_CRON=1; shift;;
    --uninstall-cron) UNINSTALL_CRON=1; shift;;
    -h|--help)        usage; exit 0;;
    -*) die "unknown option: $1 (see --help)";;
    *)  die "unexpected arg: $1";;
  esac
done

case "$DAYS" in
  ''|*[!0-9]*) die "--days must be a non-negative integer (got: $DAYS)";;
esac

[ "$(id -u)" -eq 0 ] || die "run as root."

# ---- cron install / uninstall (no renewal) ----
if [ "$INSTALL_CRON" -eq 1 ]; then
  # Sweep twice daily (certbot's own convention). A 2-day window with a
  # 12-hour cadence leaves plenty of margin for a transient failure to retry.
  # Minute 23 is arbitrary/off-the-hour so we don't stampede Let's Encrypt.
  log "cron: writing $CRON_FILE"
  cat > "$CRON_FILE" <<EOF
# lab980 certificate renewal — installed by renew-certs --install-cron
# Renew any cert expiring within $DAYS day(s). Runs at 03:23 and 15:23 daily.
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
23 3,15 * * * root $SELF --days $DAYS >> $LOG_FILE 2>&1
EOF
  chmod 644 "$CRON_FILE"
  # cron picks up /etc/cron.d changes automatically, but nudge it if present.
  systemctl reload cron 2>/dev/null || systemctl restart cron 2>/dev/null || true
  log "cron: installed. Logs -> $LOG_FILE"
  exit 0
fi

if [ "$UNINSTALL_CRON" -eq 1 ]; then
  if [ -f "$CRON_FILE" ]; then
    rm -f "$CRON_FILE"
    systemctl reload cron 2>/dev/null || systemctl restart cron 2>/dev/null || true
    log "cron: removed $CRON_FILE"
  else
    log "cron: $CRON_FILE not present (nothing to remove)"
  fi
  exit 0
fi

# ---- sweep ----
command -v certbot >/dev/null || die "certbot not found."

if [ ! -d "$LE_LIVE" ]; then
  log "no certs found ($LE_LIVE does not exist); nothing to do."
  exit 0
fi

threshold=$(( DAYS * 86400 ))
now=$(date +%s)
due=()
total=0

log "Scanning certs in $LE_LIVE (renew window: <= $DAYS day(s))"
for cert in "$LE_LIVE"/*/cert.pem; do
  [ -e "$cert" ] || continue          # literal glob when there are no certs
  total=$(( total + 1 ))
  name=$(basename "$(dirname "$cert")")

  end=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null | cut -d= -f2)
  if [ -z "$end" ]; then
    warn "$name: could not read expiry from $cert (skipping)"
    continue
  fi
  end_epoch=$(date -d "$end" +%s 2>/dev/null) || {
    warn "$name: could not parse expiry date '$end' (skipping)"; continue
  }

  remaining=$(( end_epoch - now ))
  days_left=$(( remaining / 86400 ))
  if [ "$remaining" -le "$threshold" ]; then
    log "$name: expires in ${days_left}d ($end) — DUE"
    due+=("$name")
  else
    log "$name: expires in ${days_left}d ($end) — ok"
  fi
done

if [ "$total" -eq 0 ]; then
  log "no certs found under $LE_LIVE; nothing to do."
  exit 0
fi

if [ "${#due[@]}" -eq 0 ]; then
  log "no certs due within $DAYS day(s). Done."
  exit 0
fi

# ---- renew each due cert ----
log "Renewing ${#due[@]} cert(s): ${due[*]}"
failures=0
for name in "${due[@]}"; do
  args=(renew --cert-name "$name" --non-interactive)
  [ "$FORCE" -eq 1 ]   && args+=(--force-renewal)
  [ "$DRY_RUN" -eq 1 ] && args+=(--dry-run)
  log "certbot ${args[*]}"
  if certbot "${args[@]}"; then
    log "$name: renewal request completed"
  else
    warn "$name: certbot renewal failed"
    failures=$(( failures + 1 ))
  fi
done

if [ "$failures" -gt 0 ]; then
  die "$failures of ${#due[@]} renewal(s) failed — see output above."
fi
log "Done. ${#due[@]} cert(s) renewed."
