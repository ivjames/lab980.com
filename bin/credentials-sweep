#!/usr/bin/env bash
# lab980-credentials-sweep — retire globally-placed API keys from /etc/environment,
# scoping each one to the single process that actually consumes it.
#
# Three phases, run separately:
#
#   scan             Read-only. Greps common app/config roots for the tracked
#                    key names and reports what /etc/environment still holds,
#                    plus any systemd unit already scoping a key via its own
#                    EnvironmentFile=. A name match isn't proof of a problem —
#                    a service with its own EnvironmentFile is already fine —
#                    so treat the report as a worklist, not a verdict.
#
#   migrate <dir>    Pulls the tracked keys out of /etc/environment into
#                    <dir>/.env (chmod 600, merged with whatever's already
#                    there), makes sure <dir>/.gitignore won't let it leak,
#                    then strips those lines from /etc/environment (after a
#                    timestamped backup). Confirms before touching anything
#                    unless --yes.
#
#   verify <dir>     Confirms /etc/environment is clean, a fresh-login-shell
#                    proxy has none of the tracked vars, and <dir>/.env has
#                    all of them at mode 600.
#
# /etc/environment is inherited by login shells but NOT by systemd services or
# cron jobs — so anything meant to run unattended already needed its own
# EnvironmentFile regardless of this sweep. Rotating the keys in each
# provider console after migrating is recommended (this script can't do that
# part — it's a console action, not a file operation) since they sat
# world-readable (644) in /etc/environment until now.
set -euo pipefail

KEYS_DEFAULT=(ANTHROPIC_API_KEY XAI_API_KEY MISTRAL_API_KEY GEMINI_API_KEY)
KEYS=("${KEYS_DEFAULT[@]}")
ENV_FILE="/etc/environment"
# /var/www is deliberately included even though the handoff doc's original
# grep command (/etc /home /srv /opt /root) omitted it — every lab980 app
# lives under /var/www/<name>, so a scan that skips it would miss the very
# consumers this sweep exists to find.
SCAN_ROOTS=(/etc /home /srv /opt /root /var/www)
BACKUP_DIR="/root"
SELF_NAME="credentials-sweep"

DRY_RUN=0
YES=0
NO_BACKUP=0
COMMAND=""
DIR=""

c_blue=$'\033[1;34m'; c_yellow=$'\033[1;33m'; c_red=$'\033[1;31m'; c_off=$'\033[0m'
log()  { printf '%s==>%s %s\n' "$c_blue" "$c_off" "$*"; }
warn() { printf '%swarn:%s %s\n' "$c_yellow" "$c_off" "$*" >&2; }
die()  { printf '%serror:%s %s\n' "$c_red" "$c_off" "$*" >&2; exit 1; }

usage() {
  cat <<'USAGE'
lab980-credentials-sweep — get API keys out of /etc/environment.

Usage:
  credentials-sweep scan    [options]
  credentials-sweep migrate <dir> [options]
  credentials-sweep verify  <dir> [options]

  <dir>   the consumer's project directory, e.g. /path/to/aa-eval —
          migrate writes <dir>/.env there; verify reads it back.

Options:
  --keys K1,K2,...  override the tracked key list
                    (default: ANTHROPIC_API_KEY,XAI_API_KEY,MISTRAL_API_KEY,GEMINI_API_KEY)
  --dry-run         migrate: show the plan, write and delete nothing
  --yes             migrate: skip the confirmation prompt
  --no-backup       migrate: skip the /etc/environment backup (not recommended)
  -h, --help        this help

Examples:
  credentials-sweep scan
  credentials-sweep migrate /var/www/aa-eval --dry-run
  credentials-sweep migrate /var/www/aa-eval
  credentials-sweep verify  /var/www/aa-eval
USAGE
}

# ---- parse args ----
while [ $# -gt 0 ]; do
  case "$1" in
    --keys)      IFS=',' read -ra KEYS <<< "$2"; shift 2;;
    --dry-run)   DRY_RUN=1; shift;;
    --yes|-y)    YES=1; shift;;
    --no-backup) NO_BACKUP=1; shift;;
    -h|--help)   usage; exit 0;;
    -*) die "unknown option: $1 (see --help)";;
    *)
      if [ -z "$COMMAND" ]; then COMMAND="$1";
      elif [ -z "$DIR" ]; then DIR="$1";
      else die "unexpected arg: $1"; fi
      shift;;
  esac
done

[ -n "$COMMAND" ] || { usage; exit 1; }
case "$COMMAND" in
  scan|migrate|verify) ;;
  *) die "unknown command: $COMMAND (see --help)";;
esac
if [ "$COMMAND" != "scan" ]; then
  [ -n "$DIR" ] || die "'$COMMAND' requires <dir> (see --help)"
  [ -d "$DIR" ] || die "no such directory: $DIR"
fi

REGEX="$(printf '%s|' "${KEYS[@]}")"
REGEX="${REGEX%|}"

# ---- scan ----
cmd_scan() {
  log "Tracked keys: ${KEYS[*]}"

  log "Grepping ${SCAN_ROOTS[*]} for tracked key names..."
  local hits=0
  local root
  for root in "${SCAN_ROOTS[@]}"; do
    [ -d "$root" ] || continue
    while IFS= read -r line; do
      [ -n "$line" ] || continue
      echo "  $line"
      hits=$(( hits + 1 ))
    done < <(grep -rlnE "$REGEX" "$root" \
                --exclude-dir=.git --exclude-dir=node_modules \
                --exclude="$SELF_NAME" -I 2>/dev/null || true)
  done
  if [ "$hits" -eq 0 ]; then
    log "no references found outside /etc/environment."
  else
    warn "$hits file(s) reference a tracked key name (listed above). A match"
    warn "isn't proof of a problem: check whether each file reads the key from"
    warn "its OWN scoped source (an EnvironmentFile, a chmod-600 .env it owns)"
    warn "or falls through to the global process environment — only the latter"
    warn "needs 'migrate'."
  fi

  echo
  log "$ENV_FILE:"
  local k found_in_env=0
  for k in "${KEYS[@]}"; do
    if grep -q "^${k}=" "$ENV_FILE" 2>/dev/null; then
      echo "  $k present"
      found_in_env=$(( found_in_env + 1 ))
    else
      echo "  $k absent"
    fi
  done
  if [ "$found_in_env" -eq 0 ]; then
    log "$ENV_FILE is already clean of tracked keys."
  fi

  echo
  log "systemd units with their own EnvironmentFile (already scoped — informational):"
  local any_unit=0
  local unit file
  while IFS= read -r unit; do
    [ -n "$unit" ] || continue
    file="$(systemctl show "$unit" -p EnvironmentFiles --value 2>/dev/null | awk '{print $1}')"
    [ -n "$file" ] || continue
    any_unit=1
    if [ -r "$file" ] && grep -qE "^($REGEX)=" "$file" 2>/dev/null; then
      echo "  $unit -> $file (holds a tracked key)"
    else
      echo "  $unit -> $file"
    fi
  done < <(systemctl list-units --type=service --all --no-legend --plain 2>/dev/null | awk '{print $1}')
  if [ "$any_unit" -eq 0 ]; then
    log "no service units declare an EnvironmentFile."
  fi
}

# ---- migrate ----
cmd_migrate() {
  [ "$(id -u)" -eq 0 ] || die "run as root."
  [ -f "$ENV_FILE" ] || die "$ENV_FILE not found."

  local -a found_keys=() found_vals=()
  local k v
  for k in "${KEYS[@]}"; do
    v="$(grep -m1 "^${k}=" "$ENV_FILE" 2>/dev/null | cut -d= -f2-)"
    if [ -n "$v" ]; then
      found_keys+=("$k"); found_vals+=("$v")
    else
      warn "$k not found in $ENV_FILE — skipping"
    fi
  done
  [ "${#found_keys[@]}" -gt 0 ] || die "none of the tracked keys are present in $ENV_FILE; nothing to migrate."

  log "Plan:"
  echo "    - write/update $DIR/.env with: ${found_keys[*]}"
  echo "    - chmod 600 $DIR/.env"
  echo "    - ensure $DIR/.gitignore ignores .env"
  echo "    - remove ${found_keys[*]} from $ENV_FILE"
  [ "$NO_BACKUP" -eq 1 ] || echo "    - back up $ENV_FILE to $BACKUP_DIR/environment.bak.<timestamp> first"

  if [ "$DRY_RUN" -eq 1 ]; then
    log "dry-run: no changes made."
    return 0
  fi

  if [ "$YES" -eq 0 ]; then
    printf 'Proceed? [y/N] '
    read -r reply
    case "$reply" in y|Y|yes|YES) ;; *) die "aborted.";; esac
  fi

  if [ "$NO_BACKUP" -eq 0 ]; then
    local ts backup
    ts="$(date +%Y%m%d%H%M%S)"
    backup="$BACKUP_DIR/environment.bak.$ts"
    cp -p "$ENV_FILE" "$backup"
    log "backed up $ENV_FILE -> $backup"
  fi

  # Merge: keep any existing .env lines for keys we're NOT migrating, replace
  # or add the ones we are — never clobber unrelated vars already in there.
  umask 077
  local env_tmp
  env_tmp="$(mktemp)"
  if [ -f "$DIR/.env" ]; then
    grep -vE "^(${REGEX})=" "$DIR/.env" > "$env_tmp" || true
  fi
  local i
  for i in "${!found_keys[@]}"; do
    printf '%s=%s\n' "${found_keys[$i]}" "${found_vals[$i]}" >> "$env_tmp"
  done
  mv "$env_tmp" "$DIR/.env"
  chmod 600 "$DIR/.env"
  log "wrote $DIR/.env (mode 600) with: ${found_keys[*]}"

  if [ -f "$DIR/.gitignore" ]; then
    grep -qxF ".env" "$DIR/.gitignore" || { printf '.env\n' >> "$DIR/.gitignore"; log "added .env to $DIR/.gitignore"; }
  else
    printf '.env\n' > "$DIR/.gitignore"
    log "created $DIR/.gitignore with .env"
  fi

  local strip_regex
  strip_regex="$(printf '%s|' "${found_keys[@]}")"
  strip_regex="${strip_regex%|}"
  local env_new
  env_new="$(mktemp)"
  grep -vE "^(${strip_regex})=" "$ENV_FILE" > "$env_new" || true
  cat "$env_new" > "$ENV_FILE"
  rm -f "$env_new"
  log "removed ${found_keys[*]} from $ENV_FILE"

  echo
  log "Done. Existing login shells keep the old values until re-login."
  log "Recommended: rotate ${found_keys[*]} in each provider console — they"
  log "sat world-readable in $ENV_FILE until this migration."
}

# ---- verify ----
cmd_verify() {
  local fail=0

  log "Checking $ENV_FILE..."
  local k
  for k in "${KEYS[@]}"; do
    if grep -q "^${k}=" "$ENV_FILE" 2>/dev/null; then
      warn "$k still present in $ENV_FILE"
      fail=1
    else
      echo "  $k: absent (ok)"
    fi
  done

  echo
  log "Checking $DIR/.env..."
  if [ ! -f "$DIR/.env" ]; then
    warn "$DIR/.env does not exist"
    fail=1
  else
    local mode
    mode="$(stat -c %a "$DIR/.env" 2>/dev/null || stat -f %Lp "$DIR/.env" 2>/dev/null)"
    if [ "$mode" != "600" ]; then
      warn "$DIR/.env mode is $mode, expected 600"
      fail=1
    else
      echo "  mode: 600 (ok)"
    fi
    for k in "${KEYS[@]}"; do
      if grep -qE "^${k}=.+" "$DIR/.env" 2>/dev/null; then
        echo "  $k: present (ok)"
      else
        warn "$k missing or empty in $DIR/.env"
        fail=1
      fi
    done
  fi

  echo
  log "Checking a fresh-login-shell proxy (env -i ... bash -lc env)..."
  local leaked
  leaked="$(env -i HOME="$HOME" USER="${USER:-root}" PATH="$PATH" bash -lc env 2>/dev/null | grep -E "^(${REGEX})=" || true)"
  if [ -n "$leaked" ]; then
    warn "tracked key(s) still reachable from a fresh login shell:"
    echo "$leaked" | sed 's/=.*/=<redacted>/' | sed 's/^/    /'
    fail=1
  else
    echo "  none of the tracked keys reachable (ok)"
  fi

  echo
  if [ "$fail" -eq 0 ]; then
    log "verify: all checks passed."
  else
    die "verify: one or more checks failed (see warnings above)."
  fi
}

case "$COMMAND" in
  scan)    cmd_scan;;
  migrate) cmd_migrate;;
  verify)  cmd_verify;;
esac
